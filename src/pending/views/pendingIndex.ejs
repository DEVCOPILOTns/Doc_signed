<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/Global.css">
    <link rel="stylesheet" href="/css/pending.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/nav.css">
    <link rel="icon" type="image/png" href="/images/logo_docsigned.png">
    <title>NewStetic - DocSigned</title>
    
</head>
 <%- include('../../components/nav.ejs') %>
<body>
    <div class="container">
        <div class="stats-grid">
            <div class="stat-card" id="statsCard">
                <div class="stat-icon" id="statsIcon">📄</div>
                <div class="stat-content">
                    <div class="stat-number" id="statsNumber"><%= status === 'FIRMADO' ? signedDocuments : pendingDocuments %></div>
                    <div class="stat-label" id="statsLabel"><%= status === 'FIRMADO' ? 'Documentos Firmados' : 'Solicitudes Pendientes' %></div>
                    <div class="stat-change positive"></div>
                </div>
            </div>
        </div>

        <div class="main-content">
            <div class="content-header">
                <h2 class="content-title">Firma de Solicitudes</h2>
                <p class="content-subtitle">
                    Selecciona el estado de firma que deseas visualizar. 
                    Puedes alternar entre documentos pendientes y firmados.
                </p>
            </div>

            <div class="filter-section">
                <div class="toggle-switch">
                    <button 
                        class="toggle-option left <%= status === 'PENDIENTE' ? 'active' : 'inactive' %>" 
                        id="pendingOption" 
                        data-status="PENDIENTE"
                        onclick="toggleFilter('pending')">
                        PENDIENTE
                    </button>
                    <button 
                        class="toggle-option right <%= status === 'FIRMADO' ? 'active' : 'inactive' %>" 
                        id="signedOption" 
                        data-status="FIRMADO"
                        onclick="toggleFilter('signed')">
                        FIRMADO
                    </button>
                </div>
            </div>

            <!-- Cards -->
            <div id="documentsContainer">
                <div class="documents-grid" id="pendingDocuments">
                    <% if (pendingDocs && pendingDocs.length > 0) { %>
                    <% pendingDocs.forEach(function(doc) { 
                        const estado = (doc.estado_solicitud || '').toString().toUpperCase();
                        // Usar motivo_rechazo si es RECHAZADO, si no, usar comentario normal
                        const comentario = estado === 'RECHAZADO' 
                            ? (doc.motivo_rechazo || '') 
                            : (doc.desc_comentario || '');
                    %>
                        <div class="document-card" data-id="<%= doc.id_registro_solicitud %>" data-formato="<%= doc.nombre_formato %>">
                            <div class="document-header">
                                <div>
                                    <div class="document-title">ID: <%= doc.id_registro_solicitud %></div>
                                    <div class="document-date">
                                        <%= doc.estado_solicitud === 'FIRMADO' ? 'Fecha de firma: ' : 'Fecha de solicitud: ' %>
                                        <%= (() => { 
                                            // Convertir la fecha UTC a la zona horaria local de Colombia
                                            const fecha = new Date(doc.fecha_mostrar);
                                            // Ajustar la fecha sumando 5 horas para compensar la diferencia horaria
                                            fecha.setHours(fecha.getHours() + 5);
                                            
                                            return fecha.toLocaleString('es-CO', {
                                                year: 'numeric',
                                                month: '2-digit',
                                                day: '2-digit',
                                                hour: '2-digit',
                                                minute: '2-digit',
                                                hour12: true,
                                                timeZone: 'America/Bogota'
                                            });
                                        })() %>
                                    </div>

                                </div>
                                <div class="document-status <%= doc.estado_solicitud === 'PENDIENTE' ? 'status-pending' : 'status-signed' %>">
                                                <%= doc.estado_solicitud %>
                                </div>
                            </div>
                            <div class="document-user"><h4>Solicitante:</h4> <%= doc.nombre_completo %></div>
                            <div class="document-user"><h4>Formato:</h4> <%= doc.nombre_formato %></div>
                            <% if (comentario && comentario.trim()) { %>
                                <div class="comment-section">
                                    <div class="comment-header">
                                        <div class="comment-icon">
                                            <i class="fas fa-comment"></i>
                                        </div>
                                        <h4 class="comment-title">
                                            <%= estado === 'RECHAZADO' ? 'Motivo de rechazo' : 'Comentarios' %>
                                        </h4>
                                        <span class="comment-text" style="display: none;"><%= comentario %></span>
                                        <button class="btn-view-comments" onclick="handleCommentClick(event, '<%= doc.id_registro_solicitud %>')">
                                            <%= estado === 'RECHAZADO' ? 'Ver motivo' : 'Ver' %>
                                        </button>
                                    </div>
                                </div>
                            <% } else { %>
                                <p class="no-comments-text">
                                    <%= estado === 'RECHAZADO' ? 'Sin motivo registrado' : 'No hay comentarios para esta solicitud' %>
                                </p>
                            <% } %>

                        </div>
                    <% }); %>
                    <% } else { %>
                        <div>No hay solicitudes pendientes.</div>
                    <% } %>
                </div>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" id="paginationContainerPending">
                <nav aria-label="Page navigation">
                    <ul class="pagination" id="paginationListPending"></ul>
                </nav>
            </div>
            <div class="pagination-info" id="paginationInfoPending"></div>
        </div>
    </div>
               <div id="myModal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <div style="display: flex; align-items: center; gap: var(--space-3); flex: 1;">
                            <svg style="width: 24px; height: 24px; opacity: 0.9;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                            <h2>Detalles de la Solicitud</h2>
                        </div>
                        <div style="display: flex; gap: var(--space-2); align-items: center;">
                            <% if (status !== 'FIRMADO') { %>
                                <button class="btn-sign-all" id="signAllBtn" onclick='signAllDocuments()' title="Firmar todos los documentos">
                                    <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                        <path d="M9 12l2 2 4-4"/>
                                        <path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/>
                                    </svg>
                                    Firmar
                                </button>
                                <button class="btn-reject" id="rejectBtn" onclick='rejectApplication()' title="Rechazar esta solicitud">
                                    <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                        <path d="M18 6L6 18"/>
                                        <path d="M6 6l12 12"/>
                                        <path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/>
                                    </svg>
                                    Rechazar
                                </button>
                            <% } %>
                        </div>
                        <span id="closeModalBtn" class="close" title="Cerrar">&times;</span>
                    </div>
                    
                    <div class="modal-body">
                        <div class="detalles-grid">
                            <div class="detalles-info"></div>
                            <div class="pdf-preview">
                                <iframe id="pdfViewer" width="100%" height="100%"></iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

    <!-- Modal de Carga para Firma - Por encima de todo -->
    <div id="loadingModal" class="loading-modal">
        <div class="loading-content">
            <div class="logo-container">
                <img src="/images/logo_docsigned.png" alt="DocSigned" class="loading-logo">
            </div>
            <h2>Procesando tu firma...</h2>
            <div class="loading-spinner">
                <div class="spinner"></div>
            </div>
            <p>Por favor espera mientras se procesa tu firma digital</p>
        </div>
    </div>

    <script src="/js/pending.controller.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Variables globales con los datos de estadísticas
        const stats = {
            pendientes: <%= pendingDocuments %>,
            firmados: <%= signedDocuments %>
        };

        // Actualizar tarjeta de estadísticas basada en el estado actual
        function updateStatsCard(status) {
            const statsIcon = document.getElementById('statsIcon');
            const statsNumber = document.getElementById('statsNumber');
            const statsLabel = document.getElementById('statsLabel');

            if (status === 'FIRMADO') {
                statsIcon.textContent = '✓';
                statsIcon.classList.remove('pending');
                statsIcon.classList.add('signed');
                statsNumber.textContent = stats.firmados;
                statsLabel.textContent = 'Documentos Firmados';
            } else {
                statsIcon.textContent = '📄';
                statsIcon.classList.remove('signed');
                statsIcon.classList.add('pending');
                statsNumber.textContent = stats.pendientes;
                statsLabel.textContent = 'Solicitudes Pendientes';
            }
        }

        // Inicializar con el estado actual
        const currentStatus = '<%= status %>';
        updateStatsCard(currentStatus);
    </script>

<%- include('../../components/footer.ejs') %>
</body>
</html>