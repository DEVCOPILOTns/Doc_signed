<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/Global.css">
    <link rel="stylesheet" href="/css/masiveSign.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/nav.css">
    <link rel="icon" type="image/png" href="/images/logo_docsigned.png">
    <title>NewStetic - NSigned</title>
</head>
<body>
    
    <%- include('../../components/nav.ejs') %>
    
    <!-- Modal de Carga -->
    <div id="loadingModal" class="loading-modal">
        <div class="loading-content">
            <div class="logo-container">
                <img src="/images/logo_docsigned.png" alt="DocSigned" class="loading-logo">
            </div>
            <h2>Procesando tu solicitud...</h2>
            <div class="loading-spinner">
                <div class="spinner"></div>
            </div>
            <p>Por favor espera mientras se envían los documentos y se notifica a los firmantes</p>
        </div>
    </div>
    
    <!-- Main Container -->
    <div class="container">
        <form  id="uploadForm" class="main-card" action="/api/masiveSign/upload" method="POST" enctype="multipart/form-data">
            <!-- Progress Bar -->
            <div class="progress-container">
                <div class="progress-steps">
                    <div class="progress-line">
                        <div class="progress-line-active" id="progressLine"></div>
                    </div>
                    <div class="step active" data-step="1">
                        <div class="step-circle">1</div>
                        <span class="step-label">Cargar Documentos</span>
                    </div>
                    <div class="step" data-step="2">
                        <div class="step-circle">2</div>
                        <span class="step-label">Revisar y Confirmar</span>
                    </div>
                    <div class="step" data-step="3">
                        <div class="step-circle">✓</div>
                        <span class="step-label">Completado</span>
                    </div>
                </div>
            </div>

            <!-- Content Area -->
            <div class="content-area">
                <!-- Step 1: Upload Documents -->
                <div class="step-content active" id="step1">
                    <h2 class="step-title">📄 Cargar Documentos Masivamente</h2>
                    <p class="step-description">
                        Seleccione o arrastre los documentos que desea firmar digitalmente. 
                        Formatos permitidos: PDF
                    </p>

                    <div class="format-selects-container"> 
                        <div class="Format-list">
                        <h4>Selecciona el tipo de formato</h4>
                        <!-- IMPORTANTE: dispara la carga de coordenadas -->
                        <select id="formatSelect" name="formato" style="padding:8px; border-radius:6px; width:100%;">
                            <option value="" disabled selected>-- Selecciona un formato --</option>
                            <% if (formats && formats.length > 0) { %>
                                <% formats.forEach(function(format) { %>
                                    <option value="<%= format.id_registro_formato %>"><%= format.nombre_formato %></option>
                                <% }); %>
                            <% } else { %>
                                <option value="" disabled>No hay formatos disponibles</option>
                            <% } %>
                        </select>
                    </div>
       
    
                    </div>
                    <div class="section-comments">
                        <h4>Comentarios (opcional)</h4>
                        <textarea id="comments" name="comments" rows="3" placeholder="Agrega comentarios adicionales aquí..." style="width:100%; padding:8px; border-radius:6px;"></textarea>
                    </div>

                    <div class="upload-area" onclick="document.getElementById('fileInput').click()">
                        <div class="upload-icon">📁</div>
                        <div class="upload-text">Haga clic para seleccionar archivos</div>
                        <div class="upload-subtext">o arrastre y suelte sus documentos aquí</div>
                        <!-- Cambiar el input de archivos -->
                        <input 
                            type="file" 
                            id="fileInput" 
                            name="files" 
                            multiple 
                            accept=".pdf,application/pdf"
                            style="display: none;">
                    </div>

                    <div class="file-list" id="fileList">

                        <!-- Files will appear here -->

                    </div>

                    <div class="button-group">
                        <button type="button" class="btn btn-primary" onclick="nextStep()">
                            Continuar
                            <span>→</span>
                        </button>
                    </div>
                </div>

                <!-- Step 2: Add Signature -->

                <!-- Step 3: Review -->
                <div class="step-content" id="step2">
                    <h2 class="step-title">👁️ Revisar y Confirmar</h2>
                    <p class="step-description">
                        Revise los documentos y su firma antes de proceder con la firma digital
                    </p>
                    
                    <div style="background: var(--light-bg); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
                        <h3 style="color: var(--text-dark); margin-bottom: 1rem;">Resumen de documentos</h3>
                        <div id="documentSummary">
                            <!-- Document summary will appear here -->
                        </div>
                    </div>

                    <div class="button-group">
                        <button type="button" class="btn btn-secondary" onclick="previousStep()">
                            <span>←</span>
                            Atrás
                        </button>
                        <button id="submitBtn" type="submit" class="btn btn-primary" onclick="nextStep()" >
                            Continuar
                            <span>→</span>
                        </button>
                    </div>
                </div>

                <!-- Step 4: Success -->
                <div class="step-content" id="step3">
                    <div class="success-container">
                        <div class="success-icon">✓</div>
                        <h2 class="success-title">¡Solicitud Enviada Exitosamente!</h2>
                        <p class="success-message">
                            Su solicitud ha sido Enviada exitosamente.
                        </p>
                        
                        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">

                        </div>
                        
                        <div style="margin-top: 2rem;">
                            <button type="button" class="btn btn-secondary" onclick="resetProcess()">
                                Firmar Nuevos Documentos
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <!-- Librerías necesarias para firmar/descargar -->
    <script src="https://unpkg.com/pdf-lib/dist/pdf-lib.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>

    <!-- Tu controlador -->
    <script src="/js/FirmasMasivas.controller.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Mostrar modal de carga al cargar la página
        document.addEventListener('DOMContentLoaded', () => {
            const loadingModal = document.getElementById('loadingModal');
            if (loadingModal) {
                // Mostrar el modal
                loadingModal.style.display = 'flex';
                
                // Ocultar el modal después de 1.5 segundos
                setTimeout(() => {
                    loadingModal.style.display = 'none';
                }, 1500);
            }
        });
    </script>

    <%- include('../../components/footer.ejs') %>

</body>
</html>
