<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/Global.css">
    <link rel="stylesheet" href="/css/application.css">
    <link rel="stylesheet" href="/css/nav.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="icon" type="image/png" href="/images/logo_docsigned.png">
    <title>NewStetic - NSigned</title>
</head>
    <%- include('../../components/nav.ejs') %> 
<body>
    <div class="container">
        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon total">📄</div>
                <div class="stat-content">
                    <div class="stat-number" id="totalCount"><%= countTotal %></div>
                    <div class="stat-label">Total Solicitudes</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon pending">⏰</div>
                <div class="stat-content">
                    <div class="stat-number" id="pendingCount"><%= countPending %></div>
                    <div class="stat-label">Pendientes</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon approved">✓</div>
                <div class="stat-content">
                    <div class="stat-number" id="approvedCount"><%= countSigned %></div>
                    <div class="stat-label">Aprobadas</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon rejected">✕</div>
                <div class="stat-content">
                    <div class="stat-number" id="rejectedCount"><%= countRejected %></div>
                    <div class="stat-label">Rechazadas</div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <div class="content-header">
                <h2 class="content-title">Gestión de Solicitudes</h2>
                <p class="content-subtitle">
                    Consulta y administra todas las solicitudes realizadas en el sistema
                </p>
            </div>

            <!-- Filters Section -->
            <div class="filters-container">
                <div class="search-container">
                    <span class="search-icon">🔍</span>
                    <input
                        type="text"
                        id="searchInput"
                        class="search-input"
                        placeholder="Buscar por ID..."
                    />
                    
                    <span class="search-icon">👤</span>
                    <input
                        type="text"
                        id="signerFilter"
                        class="search-input"
                        placeholder="Filtrar por firmante..."
                    />
                </div>

                <div class="filter-buttons">

                    <select id="statusFilter" class="select-filter">
                        <option value="TODOS">Todos los estados</option>
                        <option value="PENDIENTE">Pendiente</option>
                        <option value="FIRMADO">Firmado</option>
                        <option value="RECHAZADO">Rechazado</option>
                    </select>

                    <input 
                        type="month" 
                        id="dateFilter" 
                        class="select-filter"
                        title="Elige el período"
                    >

                </div>
            </div>

            <!-- Results Count -->
            <div class="results-count" id="resultsCount">
                Mostrando 0 de 0 solicitudes
            </div>

            <!-- Mensaje de sin coincidencias -->
            <div class="no-results-message" id="noResultsMessage" style="display: none;">
                <p>No hay coincidencias para los filtros aplicados</p>
            </div>

            <!-- Documents Grid: renderizado server-side similar a la vista de pendientes -->
            <div id="documentsContainer">
                <div class="documents-grid" id="pendingDocuments">
                    <% if (applicationDocs && applicationDocs.length > 0) { %>
                        <% applicationDocs.forEach(function(doc) { 
                            const id = doc.id_registro_solicitud || doc.id || doc.id_solicitud || '';
                            const estado = (doc.estado_solicitud || doc.estado || '').toString().toUpperCase();
                            const fechaRaw = doc.fecha_mostrar || doc.fecha || doc.fecha_creacion;
                            const nombre = doc.nombre_usuario || doc.usuario || doc.nombre_completo || '';
                            const cedula = doc.cedula || doc.identificacion || '';
                            // Usar motivo_rechazo si es RECHAZADO, si no, usar comentario normal
                            const comentario = estado === 'RECHAZADO' 
                                ? (doc.motivo_rechazo || doc.razon_rechazo || '')
                                : (doc.desc_comentario || doc.comentario || doc.observacion || '');
                            const firmanteName = doc.nombre_firmante || doc.firmante || ('Firmante ' + (doc.id_formato  || 'N/A'));
                            const firmanteId = doc.id_formato  || null;
                        %>
                            <div class="document-card page-item" data-id="<%= id %>" data-comment="<%= comentario || '' %>">
                                <div class="document-header">
                                    <div>
                                        <div class="document-title">ID: <%= id %></div>
                                        <div class="document-date">
                                            <% if (doc.fechaAMostrar) { %>
                                                <%= doc.etiquetaFecha %>
                                                <%= (() => {
                                                    const fecha = new Date(doc.fechaAMostrar);
                                                    fecha.setHours(fecha.getHours() + 5);
                                                    return fecha.toLocaleString('es-CO', {
                                                        year: 'numeric',
                                                        month: '2-digit',
                                                        day: '2-digit',
                                                        hour: '2-digit',
                                                        minute: '2-digit',
                                                        hour12: true,
                                                        timeZone: 'America/Bogota'
                                                    });
                                                })() %>
                                            <% } else { %>
                                                <%= doc.etiquetaFecha %> NULL
                                            <% } %>
                                        </div>
                                    </div>
                                    <% const estadoClass = 'status-' + (estado || '').replace(/\s+/g, '_'); %>
                                    <div class="document-status <%= estadoClass %>">
                                        <%= estado %>
                                    </div>
                                </div>

                                <div class="document-user"><h4>Solicitante:</h4><%= applicationName %></div>

                                <!-- Mostrar Formato -->
                                <div class="document-user"><h4>Formato:</h4><%= doc.nombre_formato || 'Sin formato asignado' %></div>

                                <!-- Mostrar etapa actual -->
                                <% if (estado !== 'FIRMADO' && doc.nombreEtapaActual && doc.nombreEtapaActual !== 'N/A') { %>
                                    <div class="document-user"><h4>Etapa Actual:</h4><%= doc.nombreEtapaActual %></div>
                                <% } else if (estado === 'FIRMADO') { %>
                                    <div class="document-user"><h4>Estado:</h4>Completamente Firmado</div>
                                <% } %>

                                <!-- Mostrar firmantes con botón de despliegue -->
                                <div class="firmantes-section">
                                    <div class="firmantes-header">
                                        <span class="firmantes-icon">👤</span>
                                        <strong>Firmantes</strong>
                                        <button class="btn-toggle-firmantes" onclick="toggleFirmantes(this, event)" title="Ver lista de firmantes">
                                            <span class="toggle-icon">▼</span>
                                        </button>
                                    </div>
                                    <div class="firmantes-list" style="display: none;">
                                        <% if (doc.nombresFirmantes && doc.nombresFirmantes.length > 0) { %>
                                            <ul class="firmantes-ul">
                                                <% doc.nombresFirmantes.forEach((firmante, index) => { %>
                                                    <li class="firmante-item">
                                                        <span class="firmante-number"><%= index + 1 %></span>
                                                        <span class="firmante-name"><%= firmante %></span>
                                                    </li>
                                                <% }); %>
                                            </ul>
                                        <% } else { %>
                                            <p class="no-firmantes">No hay firmantes registrados</p>
                                        <% } %>
                                    </div>
                                </div>
                                

                                <!-- Sección de comentarios -->
                                <% if (comentario && comentario.trim()) { %>
                                    <div class="comment-section">
                                        <div class="comment-header"> 
                                            <div class="comment-icon">
                                                <i class="fas fa-comment"></i>
                                            </div>
                                            <h4 class="comment-title">
                                                <%= estado === 'RECHAZADO' ? 'Motivo de rechazo' : 'Comentarios' %>
                                            </h4>
                                            <span class="comment-text" style="display: none;"><%= comentario %></span>
                                            <button class="btn-view-comments" onclick="handleCommentClick(event, '<%= id %>')">
                                                <%= estado === 'RECHAZADO' ? 'Ver' : 'Ver' %>
                                            </button>
                                        </div>
                                    </div>
                                <% } else { %>
                                    <p class="no-comments-text">
                                        <%= estado === 'RECHAZADO' ? 'Sin motivo registrado' : 'No hay comentarios para esta solicitud' %>
                                    </p>
                                <% } %>
                                
                                <% if (estado === 'FIRMADO') { %>
                                    <div class="document-actions-card">
                                        <button class="btn-download-card" onclick="downloadAllApplicationDocumentsById('<%= id %>')" title="Descargar todos los documentos">
                                            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                                <polyline points="7 10 12 15 17 10"/>
                                                <line x1="12" y1="15" x2="12" y2="3"/>
                                            </svg>
                                            Descargar Todo
                                        </button>
                                    </div>
                                <% } %>
                            </div>
                        <% }); %>
                     <% } else { %>
                         <div>No hay solicitudes.</div>
                     <% } %>
                </div>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" id="paginationContainer">
                <nav aria-label="Page navigation">
                    <ul class="pagination" id="paginationList"></ul>
                </nav>
            </div>
            <div class="pagination-info" id="paginationInfo"></div>
        </div>
    </div>

    <!-- Modal -->
    <div id="myModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <div style="display: flex; align-items: center; gap: var(--space-3); flex: 1;">
                    <svg style="width: 24px; height: 24px; opacity: 0.9;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <h2>Detalles de la Solicitud</h2>
                </div>
                <span id="closeModal" class="close" title="Cerrar">&times;</span>
            </div>
            <div class="modal-body">
                <div class="detalles-grid">
                    <div class="detalles-info"></div>
                    <div class="pdf-preview">
                        <iframe id="pdfViewer" width="100%" height="100%"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="/js/application.controller.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <%- include('../../components/footer.ejs') %>
</body>
</html>