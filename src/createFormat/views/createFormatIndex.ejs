<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NewStetic - DocSigned</title>
     <link rel="stylesheet" href="/css/Global.css">
    <link rel="stylesheet" href="/css/createFormat.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/nav.css">
    <link rel="icon" type="image/png" href="/images/logo_docsigned.png">
</head>
<body>
    <%- include('../../components/nav.ejs') %>
    

    <!-- Modal de Carga -->
    <div id="loadingModal" class="loading-modal">
        <div class="loading-content">
            <div class="logo-container">
                <img src="/images/logo_docsigned.png" alt="DocSigned" class="loading-logo">
            </div>
            <h2>Procesando...</h2>
            <div class="loading-spinner">
                <div class="spinner"></div>
            </div>
            <p>Por favor espera mientras se procesa tu solicitud</p>
        </div>
    </div>

    <!-- Main Container -->
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <h1 class="page-title">
                <span>📝</span>
                Formatos
            </h1>
            <p class="page-subtitle">
                Configura un nuevo formato de firma con las etapas y firmantes necesarios
            </p>
            <br>
                        <!-- CreateFormat -->
            <a href="#" class="create-format-btn" id="createFormatBtn" onclick="openFormatModal(event)">
                <!-- Icono de crear formato -->
                <span class="mdi mdi-file-document-edit"></span>
                <span>+Crear Formato</span>
            </a>
        </div>
    </div>


        <!-- Contenedor consulta de formatos -->
    <div class="container">
        <div class="formats-list">
            <div class="formats-header">
                <h2 class="formats-title">
                    <span class="formats-icon">📋</span>
                    Formatos Existentes
                </h2>
                <p class="formats-subtitle">Listado de todos los formatos de firma disponibles</p>
            </div>
            
            <% if (formats && formats.length > 0) { %>
                <div class="format-grid">
                    <% formats.forEach(function(format) { %>
                        <div class="format-card <%= format.estado === 'inactivo' ? 'format-card-inactive' : '' %>">
                            <div class="format-card-header">
                                <span class="format-id"><%= format.id_registro_formato %></span>
                                <h3 class="format-name">
                                    <span class="format-icon-small">📄</span>
                                    <%= format.nombre_formato %>
                                </h3>
                                <span class="format-status <%= format.estado === 'activo' ? 'status-active' : 'status-inactive' %>">
                                    <%= format.estado === 'activo' ? '● Activo' : '● Inactivo' %>
                                </span>
                            </div>

                            <% if (format.descripcion) { %>
                                <p class="format-description">
                                    <%= format.descripcion %>
                                </p>
                            <% } %>

                            <div class="format-meta">
                                <div class="meta-item">
                                    <span class="meta-label">📅 Fecha de Creación</span>
                                    <span class="meta-value">
                                        <%= format.fecha_creacion ? new Date(format.fecha_creacion).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: '2-digit' }) : 'N/A' %>
                                    </span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">✍️ Firmantes</span>
                                    <span class="meta-value format-signer-count">
                                        <%= format.cantidad_firmantes || 0 %>
                                    </span>
                                </div>
                            </div>

                            <div class="format-actions">
                                <button class="btn-action btn-edit" title="Editar formato" onclick="editFormat(<%= format.id_registro_formato || '' %>)">
                                    <span>✏️</span>
                                    Editar
                                </button>
                                <button 
                                    class="btn-action <%= format.estado === 'activo' ? 'btn-delete' : 'btn-activate' %>" 
                                    title="<%= format.estado === 'activo' ? 'Inhabilitar formato' : 'Activar formato' %>" 
                                    onclick="<%= format.estado === 'activo' ? 'disableFormat' : 'activateFormat' %>(<%= format.id_registro_formato || '' %>)"
                                >
                                    <span><%= format.estado === 'activo' ? '🗑️' : '✅' %></span>
                                    <%= format.estado === 'activo' ? 'Inhabilitar' : 'Activar' %>
                                </button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <h3>No hay formatos creados</h3>
                    <p>Comienza creando tu primer formato de firma haciendo clic en el botón <strong>+Crear Formato</strong></p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Modal de Creación de Formato -->
    <div id="formatModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Crear Nuevo Formato</h2>
                <button type="button" class="modal-close" onclick="closeFormatModal()">×</button>
            </div>
            <div class="modal-body">
        <form id="formatoForm" class="form-card" >
            <!-- Información Básica -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon">📋</div>
                    <h2 class="section-title">Información Básica</h2>
                </div>

                <div class="form-group">
                    <label for="nombreFormato" class="form-label">
                        Nombre del Formato
                        <span class="required">*</span>
                    </label>
                    <input 
                        type="text" 
                        id="nombreFormato" 
                        name="nombreFormato" 
                        class="form-input"
                        placeholder="Ej: Formato de Solicitud de Vacaciones"
                        required
                    />
                    <span class="form-help">Nombre descriptivo que identifique este formato</span>
                </div>

                <div class="form-group">
                    <label for="descripcion" class="form-label">
                        Descripción
                    </label>
                    <textarea 
                        id="descripcion" 
                        name="descripcion" 
                        class="form-textarea"
                        placeholder="Describe el propósito y uso de este formato..."
                    ></textarea>
                    <span class="form-help">Información adicional sobre el formato (opcional)</span>
                </div>

                <div class="form-group">
                    <label for="estado" class="form-label">
                        Estado
                        <span class="required">*</span>
                    </label>
                    <select id="estado" name="estado" class="form-select" required>
                        <option value="activo" selected>Activo</option>
                        <option value="inactivo">Inactivo</option>
                    </select>
                    <span class="form-help">Los formatos activos estarán disponibles para su uso</span>
                </div>
            </div>

            <!-- Etapas de Firma -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon">✍️</div>
                    <h2 class="section-title">Etapas de Firma</h2>
                </div>

                <div id="etapasContainer" class="etapas-container">
                    <!-- Las etapas se agregarán aquí dinámicamente -->
                </div>

                <button type="button" class="btn btn-add" id="btnAddEtapa">
                    <span style="font-size: 1.5rem;">+</span>
                    Agregar Etapa de Firma
                </button>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <button type="button" class="btn btn-secondary" onclick="closeFormatModal()">
                    Cancelar
                </button>
                <button type="submit" class="btn btn-success">
                    <span>💾</span>
                    Guardar Formato
                </button>
            </div>
        </form>
            </div>
        </div>
    </div>




    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Pasar los datos de firmantes desde EJS al JavaScript
        const signerUsersData = <%-  JSON.stringify(signerUsers || []) %>;
    </script>
    <script src="/js/createFormat.controller.js"></script>

    <%- include('../../components/footer.ejs') %>
</body>
</html>